{
  "name": "@marionette/shared",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ids-node": {
      "import": "./dist/ids-node.js",
      "types": "./dist/ids-node.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "ids-node": ["./dist/ids-node.d.ts"]
    }
  },
  "scripts": {
    "dev": "tsc -w",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
