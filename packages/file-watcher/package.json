{
  "name": "@marionette/file-watcher",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "marionette-watcher": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@marionette/shared": "workspace:*",
    "chokidar": "~4.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
