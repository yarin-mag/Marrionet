{
  "name": "marionette",
  "private": true,
  "version": "1.2.0",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web,proxy,watcher -c blue,green,magenta,cyan \"pnpm --filter marionette-server dev\" \"pnpm --filter marionette-web dev\" \"pnpm --filter @marionette/api-proxy dev\" \"pnpm --filter @marionette/file-watcher dev\"",
    "dev:server": "pnpm --filter marionette-server dev",
    "dev:web": "pnpm --filter marionette-web dev",
    "dev:proxy": "pnpm --filter @marionette/api-proxy dev",
    "dev:watcher": "pnpm --filter @marionette/file-watcher dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\" --ignore-path .prettierignore"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3"
  }
}
