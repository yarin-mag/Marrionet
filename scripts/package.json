{
  "name": "marionette-scripts",
  "version": "2.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-wrapper": "dist/index.js"
  },
  "description": "Marionette wrapper scripts and utilities",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "bench:startup": "node benchmarks/startup.bench.js",
    "bench:message": "node benchmarks/message.bench.js",
    "bench:memory": "node benchmarks/memory.bench.js",
    "bench:cpu": "node benchmarks/cpu.bench.js",
    "bench:report": "node benchmarks/report.js",
    "install-wrapper": "npm run build && npm link"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "node-pty": "^1.1.0",
    "pidusage": "^3.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
